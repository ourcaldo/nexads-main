{
    "proxy": {
        "type": "http",
        "credentials": "",
        "file": "proxy.txt"
    },
    "browser": {
        "headless_mode": "virtual",
        "disable_ublock": true,
        "random_activity": true,
        "auto_accept_cookies": true,
        "prevent_redirects": true,
        "activities": [
            "scroll",
            "hover",
            "click"
        ]
    },
    "session": {
        "enabled": true,
        "count": 0,
        "min_time": 4,
        "max_time": 5
    },
    "threads": 10,
    "os_fingerprint": [
        "windows",
        "macos",
        "linux"
    ],
    "device_type": {
        "mobile": 0,
        "desktop": 100
    },
    "referrer": {
        "types": [
            "social"
        ],
        "organic_keywords": "insurance for home\nhome insurance"
    },
    "explorer": {
        "enabled": true,
        "gate_url": "https://app.camarjaya.co.id/",
        "min_time": 30,
        "max_time": 60
    },
    "urls": [
        {
            "url": "https://app.camarjaya.co.id/",
            "min_time": 5,
            "max_time": 10
        },
        {
            "url": "https://app.camarjaya.co.id/insights/",
            "min_time": 10,
            "max_time": 20
        },
        {
